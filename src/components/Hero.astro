---
---

<section class='relative min-h-screen flex items-center overflow-hidden bg-base-100'>
  <canvas id='hero-canvas' class='absolute inset-0 w-full h-full'></canvas>

  <!-- Gradient to keep text readable on the left -->
  <div
    class='absolute inset-0 pointer-events-none z-[1] text-grad'
    aria-hidden='true'
  ></div>

  <div class='relative z-10 w-full max-w-5xl mx-auto px-8 sm:px-12 lg:px-20 py-28'>
    <p class='font-mono text-xs text-primary mb-5 hero-anim' style='animation-delay:0s' aria-hidden='true'>
      <span class='opacity-40'>~/</span>paul-vlaswinkel
    </p>

    <h1
      class='font-sans font-extrabold leading-[1.02] tracking-tight text-base-content mb-4 hero-anim'
      style='font-size: clamp(2.8rem, 8vw, 6.5rem); animation-delay: 0.1s'
    >
      Paul<br />Vlaswinkel
    </h1>

    <p class='font-sans font-medium text-lg text-base-content/50 mb-6 hero-anim' style='animation-delay: 0.18s'>
      Software Developer &amp; Engineer
    </p>

    <p class='font-sans text-sm text-base-content/55 max-w-sm leading-relaxed mb-9 hero-anim' style='animation-delay: 0.26s'>
      I build precise, purposeful software — IoT security, data visualizations, and full-stack applications.
    </p>

    <div class='flex flex-wrap items-center gap-3 hero-anim' style='animation-delay: 0.34s'>
      <a href='mailto:paul.vlaswinkel@gmail.com' class='cta-primary font-sans font-semibold text-sm px-6 py-2.5'>
        Get in touch
      </a>
      <a href='#projects' class='cta-ghost font-sans font-medium text-sm px-6 py-2.5'>
        View projects <span class='opacity-50'>↓</span>
      </a>
    </div>
  </div>
</section>

<style>
  .text-grad {
    background: linear-gradient(
      90deg,
      oklch(var(--b1)) 0%,
      oklch(var(--b1) / 0.85) 35%,
      oklch(var(--b1) / 0.2) 65%,
      transparent 100%
    );
  }
  @media (max-width: 640px) {
    .text-grad {
      background: linear-gradient(
        180deg,
        oklch(var(--b1)) 30%,
        oklch(var(--b1) / 0.7) 60%,
        transparent 100%
      );
    }
  }

  .cta-primary {
    display: inline-block; text-decoration: none;
    background: oklch(var(--p)); color: oklch(var(--pc));
    border-radius: 6px;
    transition: opacity 0.15s, transform 0.15s;
  }
  .cta-primary:hover { opacity: 0.88; transform: translateY(-1px); }

  .cta-ghost {
    display: inline-block; text-decoration: none;
    border: 1px solid oklch(var(--bc) / 0.15);
    color: oklch(var(--bc) / 0.7);
    border-radius: 6px;
    transition: color 0.15s, border-color 0.15s;
  }
  .cta-ghost:hover { color: oklch(var(--p)); border-color: oklch(var(--p) / 0.4); }

  @keyframes fade-up {
    from { opacity: 0; transform: translateY(14px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .hero-anim { opacity: 0; animation: fade-up 0.55s ease forwards; }
</style>

<script>
(() => {
  const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement;
  const ctx    = canvas.getContext('2d')!;

  // ── Theme-aware colors ──────────────────────────────
  function isDark() {
    return document.documentElement.getAttribute('data-theme') === 'dark';
  }
  function getBg()        { return isDark() ? '#0F172A' : '#FFFFFF'; }
  function getParticleRGB(): [number,number,number] {
    return isDark() ? [56, 189, 248] : [2, 132, 199];
  }

  // ── Types ───────────────────────────────────────────
  interface Particle {
    x: number; y: number;
    vx: number; vy: number;
    size: number; opacity: number;
  }
  interface Ripple {
    x: number; y: number;
    r: number; maxR: number; alpha: number;
  }

  // ── State ───────────────────────────────────────────
  let W = 0, H = 0;
  const particles: Particle[] = [];
  const ripples:   Ripple[]   = [];
  const mouse = { x: -9999, y: -9999 };
  const MAX_DIST    = 130;
  const REPEL_DIST  = 90;
  const MAX_SPEED   = 1.2;

  // ── Setup ───────────────────────────────────────────
  function countParticles() {
    return W < 640 ? 45 : W < 1024 ? 75 : 110;
  }

  function resize() {
    const section = canvas.parentElement!;
    W = canvas.width  = section.offsetWidth;
    H = canvas.height = section.offsetHeight;
  }

  function initParticles() {
    particles.length = 0;
    const n = countParticles();
    for (let i = 0; i < n; i++) {
      particles.push({
        x:       Math.random() * W,
        y:       Math.random() * H,
        vx:      (Math.random() - 0.5) * 0.6,
        vy:      (Math.random() - 0.5) * 0.6,
        size:    Math.random() * 1.5 + 1,
        opacity: Math.random() * 0.4 + 0.35,
      });
    }
  }

  // ── Update ──────────────────────────────────────────
  function update() {
    const [r,g,b] = getParticleRGB();

    for (const p of particles) {
      // Mouse repulsion
      const dx = p.x - mouse.x;
      const dy = p.y - mouse.y;
      const d  = Math.sqrt(dx * dx + dy * dy);
      if (d < REPEL_DIST && d > 0) {
        const force = ((REPEL_DIST - d) / REPEL_DIST) * 0.06;
        p.vx += (dx / d) * force;
        p.vy += (dy / d) * force;
      }

      // Speed cap
      const speed = Math.sqrt(p.vx * p.vx + p.vy * p.vy);
      if (speed > MAX_SPEED) {
        p.vx = (p.vx / speed) * MAX_SPEED;
        p.vy = (p.vy / speed) * MAX_SPEED;
      }

      // Move
      p.x += p.vx;
      p.y += p.vy;

      // Bounce
      if (p.x < 0)  { p.x = 0;  p.vx *= -0.7; }
      if (p.x > W)  { p.x = W;  p.vx *= -0.7; }
      if (p.y < 0)  { p.y = 0;  p.vy *= -0.7; }
      if (p.y > H)  { p.y = H;  p.vy *= -0.7; }

      // Gentle friction to prevent endless acceleration
      p.vx *= 0.995;
      p.vy *= 0.995;
    }

    // Update ripples
    for (let i = ripples.length - 1; i >= 0; i--) {
      const rp = ripples[i];
      rp.r     += 3.5;
      rp.alpha -= 0.018;
      if (rp.alpha <= 0) ripples.splice(i, 1);
    }
  }

  // ── Draw ────────────────────────────────────────────
  function draw() {
    const [r,g,b] = getParticleRGB();

    // Background
    ctx.fillStyle = getBg();
    ctx.fillRect(0, 0, W, H);

    // Connection lines
    for (let i = 0; i < particles.length; i++) {
      for (let j = i + 1; j < particles.length; j++) {
        const a = particles[i];
        const b_ = particles[j];
        const dx = a.x - b_.x;
        const dy = a.y - b_.y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < MAX_DIST) {
          const alpha = (1 - dist / MAX_DIST) * 0.18;
          ctx.strokeStyle = `rgba(${r},${g},${b},${alpha})`;
          ctx.lineWidth = 1;
          ctx.beginPath();
          ctx.moveTo(a.x, a.y);
          ctx.lineTo(b_.x, b_.y);
          ctx.stroke();
        }
      }
    }

    // Particles
    for (const p of particles) {
      // Glow
      ctx.globalAlpha = p.opacity * 0.18;
      ctx.fillStyle = `rgb(${r},${g},${b})`;
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.size * 3.5, 0, Math.PI * 2);
      ctx.fill();

      // Core
      ctx.globalAlpha = p.opacity;
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
      ctx.fill();
    }

    ctx.globalAlpha = 1;

    // Ripples
    for (const rp of ripples) {
      ctx.strokeStyle = `rgba(${r},${g},${b},${rp.alpha})`;
      ctx.lineWidth = 1.5;
      ctx.beginPath();
      ctx.arc(rp.x, rp.y, rp.r, 0, Math.PI * 2);
      ctx.stroke();
    }
  }

  // ── Loop ────────────────────────────────────────────
  let raf: number;
  function loop() {
    update();
    draw();
    raf = requestAnimationFrame(loop);
  }

  // ── Events ──────────────────────────────────────────
  window.addEventListener('mousemove', (e) => {
    const rect = canvas.getBoundingClientRect();
    mouse.x = e.clientX - rect.left;
    mouse.y = e.clientY - rect.top;
  });

  canvas.addEventListener('click', (e) => {
    const rect = canvas.getBoundingClientRect();
    const cx = e.clientX - rect.left;
    const cy = e.clientY - rect.top;

    // Ripple
    ripples.push({ x: cx, y: cy, r: 4, maxR: 80, alpha: 0.6 });

    // Burst: scatter nearby particles
    for (const p of particles) {
      const dx = p.x - cx;
      const dy = p.y - cy;
      const d  = Math.sqrt(dx * dx + dy * dy);
      if (d < 100 && d > 0) {
        const force = (100 - d) / 100 * 2.5;
        p.vx += (dx / d) * force;
        p.vy += (dy / d) * force;
      }
    }
  });

  window.addEventListener('resize', () => {
    resize();
    initParticles();
  });

  // Watch for theme changes
  const observer = new MutationObserver(() => { /* colors read live */ });
  observer.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });

  // ── Init ────────────────────────────────────────────
  resize();
  initParticles();
  loop();
})();
</script>
