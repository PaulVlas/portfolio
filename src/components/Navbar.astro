---
import ThemeSwitch from "./ThemeSwitch.astro";
import Github from "./buttons/Github.astro";
import Linkedin from "./buttons/Linkedin.astro";
---

<header
  id='site-nav'
  class='fixed top-0 left-0 right-0 z-50 h-14 flex items-center px-8 sm:px-12 lg:px-20 border-b border-transparent transition-all duration-200'
>
  <a
    href='/'
    class='font-mono text-sm font-medium text-base-content/70 hover:text-base-content transition-colors duration-150 mr-auto'
  >
    p4ul<span class='text-primary'>.</span>nl
  </a>

  <nav class='flex items-center gap-5' aria-label='Site navigation'>
    <div class='hidden sm:flex items-center gap-5'>
      <Github />
      <Linkedin />
    </div>
    <div class='h-4 w-px bg-base-content/15 hidden sm:block'></div>
    <ThemeSwitch />
  </nav>
</header>

<style>
  #site-nav {
    background: oklch(var(--b1) / 0);
  }
  #site-nav.scrolled {
    background: oklch(var(--b1) / 0.88);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-bottom-color: oklch(var(--bc) / 0.08);
  }
</style>

<script>
  const nav = document.getElementById('site-nav');
  function onScroll() {
    nav?.classList.toggle('scrolled', window.scrollY > 10);
  }
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
</script>
