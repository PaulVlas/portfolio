---
import { getCollection } from "astro:content";
import ProjectCard from "./ProjectCard.astro";

const projects = (await getCollection("project")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<section id='projects' class='bg-base-200 py-20 px-8 sm:px-12 lg:px-20'>
  <div class='max-w-5xl mx-auto'>
    <!-- Section header -->
    <div class='flex items-baseline justify-between mb-12 border-b border-base-300 pb-5'>
      <h2 class='font-sans font-bold text-2xl text-base-content tracking-tight'>
        Projects
      </h2>
      <span class='font-mono text-xs text-base-content/40'>{projects.length} total</span>
    </div>

    <!-- Grid -->
    <ul class='grid grid-cols-1 sm:grid-cols-2 gap-8 list-none p-0' role='list'>
      {projects.map((project) => (
        <li>
          <ProjectCard entry={project} />
        </li>
      ))}
    </ul>
  </div>
</section>
